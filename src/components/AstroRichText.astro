---
const { content, className = '' } = Astro.props;

// We manually convert the Tina AST to HTML string to avoid React SSR issues
function renderNode(node: any): string {
  if (!node) return '';
  if (typeof node === 'string') return node;
  
  if (node.type === 'text') {
    let text = node.text || '';
    if (node.bold) text = `<strong>${text}</strong>`;
    if (node.italic) text = `<em>${text}</em>`;
    return text;
  }
  
  let childrenHtml = '';
  if (node.children) {
    childrenHtml = node.children.map((child: any) => renderNode(child)).join('');
  }
  
  switch (node.type) {
    case 'p': return `<p>${childrenHtml}</p>`;
    case 'h1': return `<h1>${childrenHtml}</h1>`;
    case 'h2': return `<h2>${childrenHtml}</h2>`;
    case 'h3': return `<h3>${childrenHtml}</h3>`;
    case 'h4': return `<h4>${childrenHtml}</h4>`;
    case 'h5': return `<h5>${childrenHtml}</h5>`;
    case 'h6': return `<h6>${childrenHtml}</h6>`;
    case 'ul': return `<ul>${childrenHtml}</ul>`;
    case 'ol': return `<ol>${childrenHtml}</ol>`;
    case 'li': return `<li>${childrenHtml}</li>`;
    case 'a': return `<a href="${node.url}">${childrenHtml}</a>`;
    case 'root': return childrenHtml;
    default: return childrenHtml;
  }
}

let innerHtml = '';
if (typeof content === 'string') {
  innerHtml = `<p>${content}</p>`;
} else if (content?.type === 'root') {
  innerHtml = renderNode(content);
} else if (content) {
  try {
    innerHtml = `<p>${JSON.stringify(content)}</p>`;
  } catch {
    innerHtml = '';
  }
}
---
{innerHtml ? (
  <div class={`[&>p]:mb-4 [&>p:last-child]:mb-0 [&_strong]:font-bold [&_em]:italic [&_ul]:list-disc [&_ol]:list-decimal [&_ul]:ml-6 [&_ol]:ml-6 [&_a]:underline hover:[&_a]:text-blue-500 ${className}`} set:html={innerHtml}></div>
) : null}
