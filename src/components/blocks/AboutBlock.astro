---
import { type BlockStyle, getBlockStyleVars, getBlockClasses } from '../../utils/style';
import AstroRichText from '../AstroRichText.astro';

export interface Props {
  heading?: string;
  body?: any;
  image?: string;
  visible?: boolean;
  layout?: 'image-right' | 'image-left' | 'stacked';
  style?: BlockStyle;
}

const {
  heading = 'About JL Swimming',
  body,
  image,
  visible = true,
  layout = 'image-right',
  style,
} = Astro.props;

if (!visible) return;

const styleVars = getBlockStyleVars(style);
const styleClasses = getBlockClasses(style, 'bg-pool-50/50 theme-default');

const layoutColClass = layout === 'stacked' ? 'grid-cols-1' : 'grid-cols-1 lg:grid-cols-2';
const textOrderClass = layout === 'image-left' ? 'order-2' : 'order-1';
const imageOrderClass = layout === 'image-left' ? 'order-1' : 'order-2';
---

<section id="about" class={`relative overflow-hidden ${styleClasses}`} style={styleVars}>
  <!-- Background decorations -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-pool-100 rounded-full filter blur-[120px] opacity-50 -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-water-100 rounded-full filter blur-[100px] opacity-40 translate-y-1/2 -translate-x-1/2"></div>

  <div class="section-container relative z-10">
    <div class={`grid ${layoutColClass} gap-12 lg:gap-20 items-center`}>
      <!-- Text Content -->
      <div class={`reveal ${textOrderClass}`}>
        <!-- Label -->
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-0.5 bg-water-gradient rounded-full"></div>
          <span class="text-sm font-semibold text-water-600 uppercase tracking-wider">About Us</span>
        </div>

        <h2 class="section-heading mb-6" style={style?.headingColor ? `color: ${style.headingColor}` : ''}>
          {heading}
        </h2>

        <div class="text-lg mt-6">
          <AstroRichText content={body} className="text-gray-600" />
        </div>

        <!-- Features row -->
        <div class="mt-8 grid grid-cols-2 gap-4">
          <div class="flex items-start gap-3 p-4 rounded-xl bg-water-50/50 border border-water-100/50">
            <div class="w-10 h-10 rounded-lg bg-water-gradient flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-800 text-sm">Certified Coaches</h4>
              <p class="text-xs text-gray-500 mt-0.5">AUSTSWIM qualified instructors</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-4 rounded-xl bg-pool-50/50 border border-pool-100/50">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-pool-500 to-pool-700 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-800 text-sm">Small Classes</h4>
              <p class="text-xs text-gray-500 mt-0.5">Personalised attention for all</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Image -->
      <div class={`reveal relative ${imageOrderClass}`} style="animation-delay: 0.2s;">
        <div class="relative max-w-2xl mx-auto">
          {image ? (
            <img
              src={image}
              alt="JL Swimming — About our school"
              class="w-full h-[400px] sm:h-[500px] object-cover rounded-2xl shadow-2xl shadow-water-900/10"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-[400px] sm:h-[500px] rounded-2xl bg-gradient-to-br from-water-200 via-pool-200 to-water-300 flex items-center justify-center shadow-2xl shadow-water-900/10">
              <div class="text-center">
                <svg class="w-20 h-20 text-water-500/40 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                  <path d="M2 12c2-2 4-3 6-3s4 1 6 3 4 3 6 3" stroke-linecap="round"/>
                  <path d="M2 17c2-2 4-3 6-3s4 1 6 3 4 3 6 3" stroke-linecap="round" opacity="0.6"/>
                  <path d="M2 7c2-2 4-3 6-3s4 1 6 3 4 3 6 3" stroke-linecap="round" opacity="0.3"/>
                </svg>
                <p class="text-water-500/50 text-sm mt-3 font-medium">Swimming Excellence</p>
              </div>
            </div>
          )}

          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-4 glass-card px-5 py-3 flex items-center gap-3 animate-float">
            <div class="w-12 h-12 rounded-xl bg-water-gradient flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
            </div>
            <div>
              <div class="font-display font-bold text-water-900 text-lg">10+ Years</div>
              <div class="text-xs text-gray-500">Teaching Excellence</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
