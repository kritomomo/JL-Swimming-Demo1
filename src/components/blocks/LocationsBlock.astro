---
import { type BlockStyle, getBlockStyleVars, getBlockClasses } from '../../utils/style';
import AstroRichText from '../AstroRichText.astro';

export interface LocationItem {
  name: string;
  address?: string;
  phone?: string;
  mapEmbedUrl?: string;
  image?: string;
}

export interface Props {
  heading?: string;
  subheading?: any;
  locations?: LocationItem[];
  visible?: boolean;
  columns?: '2' | '3' | '4';
  style?: BlockStyle;
}

const {
  heading = 'Our Locations',
  subheading = 'Five convenient locations across Melbourne',
  locations = [],
  visible = true,
  columns = '3',
  style,
} = Astro.props;

if (!visible) return;

const defaultLocations: LocationItem[] = [
  {
    name: 'Knox',
    address: 'Knox Leisureworks, Boronia VIC',
    phone: '0400 000 000',
  },
  {
    name: 'Ashburton',
    address: 'Ashburton Pool & Recreation Centre, Ashburton VIC',
    phone: '0400 000 000',
  },
  {
    name: 'Ringwood',
    address: 'Aquanation, Ringwood VIC',
    phone: '0400 000 000',
  },
  {
    name: 'Mont Albert',
    address: 'Mont Albert Aquatic Centre, Mont Albert VIC',
    phone: '0400 000 000',
  },
  {
    name: 'Clayton',
    address: 'Clayton Aquatics & Health Club, Clayton VIC',
    phone: '0400 000 000',
  },
];

const displayLocations = locations && locations.length > 0 ? locations : defaultLocations;

// Color variants for location cards
const colorVariants = [
  'from-water-500 to-water-700',
  'from-pool-500 to-pool-700',
  'from-water-600 to-pool-600',
  'from-pool-600 to-water-600',
  'from-water-700 to-pool-500',
];

const styleVars = getBlockStyleVars(style);
const styleClasses = getBlockClasses(style, 'bg-white theme-default');

let gridClass = 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';
if (columns === '2') gridClass = 'grid-cols-1 sm:grid-cols-2';
if (columns === '4') gridClass = 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4';
---

<section id="locations" class={`relative overflow-hidden ${styleClasses}`} style={styleVars}>
  <!-- Background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-water-100/30 rounded-full filter blur-[150px]"></div>

  <div class="section-container relative z-10">
    <!-- Section Header -->
    <div class="mb-16 reveal">
      <div class={`flex items-center gap-2 mb-4 ${style?.textAlign === 'left' ? 'justify-start' : style?.textAlign === 'right' ? 'justify-end' : 'justify-center'}`}>
        {style?.textAlign !== 'left' && <div class="w-8 h-0.5 bg-water-gradient rounded-full"></div>}
        <span class="text-sm font-semibold text-water-600 uppercase tracking-wider">Locations</span>
        {style?.textAlign !== 'right' && <div class="w-8 h-0.5 bg-water-gradient rounded-full"></div>}
      </div>
      <h2 class="section-heading" style={style?.headingColor ? `color: ${style.headingColor}` : ''}>
        {heading}
      </h2>
      {subheading && (
        <div class={`mt-2 max-w-2xl ${style?.textAlign === 'left' ? 'mr-auto' : style?.textAlign === 'right' ? 'ml-auto' : 'mx-auto'}`}>
          <AstroRichText content={subheading} className="section-subheading" />
        </div>
      )}
    </div>

    <!-- Locations Grid -->
    <div class={`grid ${gridClass} gap-6 reveal-stagger`}>
      {displayLocations.map((loc, index) => (
        <div
          class="group relative bg-white rounded-2xl overflow-hidden shadow-lg shadow-water-900/5 hover:shadow-xl hover:shadow-water-600/10 hover:-translate-y-1 transition-all duration-500 border border-gray-100 hover:border-water-200"
          id={`location-${index}`}
        >
          {/* Image / Gradient Header */}
          {loc.image ? (
            <div class="h-40 overflow-hidden">
              <img
                src={loc.image}
                alt={`JL Swimming — ${loc.name}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
          ) : (
            <div class={`h-40 bg-gradient-to-br ${colorVariants[index % colorVariants.length]} relative flex items-center justify-center`}>
              <div class="absolute inset-0 opacity-20">
                <svg class="w-full h-full" viewBox="0 0 100 50" preserveAspectRatio="none">
                  <path d="M0,25 Q25,0 50,25 Q75,50 100,25 L100,50 L0,50 Z" fill="white" opacity="0.15"/>
                  <path d="M0,30 Q25,10 50,30 Q75,50 100,30 L100,50 L0,50 Z" fill="white" opacity="0.1"/>
                </svg>
              </div>
              <span class="relative z-10 text-3xl font-display font-bold text-white">
                {loc.name}
              </span>
            </div>
          )}

          {/* Content */}
          <div class="p-6 text-left">
            <h3 class="text-lg font-display font-semibold text-water-900">
              {loc.name}
            </h3>

            {loc.address && (
              <div class="flex items-start gap-2 mt-3 text-sm text-gray-500">
                <svg class="w-4 h-4 text-water-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {loc.address}
              </div>
            )}

            {loc.phone && (
              <div class="flex items-center gap-2 mt-2 text-sm text-gray-500">
                <svg class="w-4 h-4 text-water-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <a href={`tel:${loc.phone.replace(/\s/g, '')}`} class="hover:text-water-600 transition-colors">
                  {loc.phone}
                </a>
              </div>
            )}

            {/* Map link */}
            {loc.mapEmbedUrl && (
              <div class="mt-4 pt-4 border-t border-gray-100">
                <a
                  href={loc.mapEmbedUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-medium text-water-600 hover:text-water-700 transition-colors"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                  </svg>
                  View on Google Maps
                </a>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
