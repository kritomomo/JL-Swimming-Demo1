---
export interface SocialLinks {
  instagram?: string;
  facebook?: string;
  tiktok?: string;
}

export interface Props {
  siteName?: string;
  logo?: string;
  footerText?: string;
  socialLinks?: SocialLinks;
}

const {
  siteName = 'JL Swimming',
  logo,
  footerText = 'Melbourne\'s premier swimming school. From first strokes to elite performance, we provide expert coaching across five convenient locations.',
  socialLinks = {
    instagram: 'https://instagram.com/jlswimming'
  }
} = Astro.props;

const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Quick Links',
    links: [
      { label: 'About', href: '#about' },
      { label: 'Achievements', href: '#achievements' },
      { label: 'Locations', href: '#locations' },
      { label: 'Contact', href: '#contact' },
    ],
  },
  {
    title: 'Locations',
    links: [
      { label: 'Knox', href: '#locations' },
      { label: 'Ashburton', href: '#locations' },
      { label: 'Ringwood', href: '#locations' },
      { label: 'Mont Albert', href: '#locations' },
      { label: 'Clayton', href: '#locations' },
    ],
  },
];
---

<footer class="bg-water-950 text-white/80 relative overflow-hidden" id="site-footer">
  <!-- Decorative wave top -->
  <div class="absolute top-0 left-0 right-0 h-16 -translate-y-[99%]">
    <svg viewBox="0 0 1440 100" preserveAspectRatio="none" class="w-full h-full">
      <path fill="#172753" d="M0,40 C360,100 720,0 1080,60 C1260,80 1380,50 1440,40 L1440,100 L0,100 Z"/>
    </svg>
  </div>

  <div class="section-container pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          {logo ? (
            <img src={logo} alt={siteName} class="w-10 h-10 object-contain" />
          ) : (
            <div class="w-10 h-10 rounded-xl bg-water-gradient flex items-center justify-center">
              <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M2 12c2-2 4-3 6-3s4 1 6 3 4 3 6 3" stroke-linecap="round"/>
                <path d="M2 17c2-2 4-3 6-3s4 1 6 3 4 3 6 3" stroke-linecap="round" opacity="0.6"/>
              </svg>
            </div>
          )}
          <span class="font-display font-bold text-xl text-white">{siteName}</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed max-w-md">
          {footerText}
        </p>

        <!-- Social Links -->
        <div class="flex items-center gap-3 mt-6">
          {socialLinks.instagram && (
            <a
              href={socialLinks.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-xl bg-white/10 hover:bg-water-600 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
              aria-label="Instagram"
              id="footer-instagram"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          )}
          {socialLinks.facebook && (
            <a
              href={socialLinks.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-xl bg-white/10 hover:bg-water-600 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
              aria-label="Facebook"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22.675 0H1.325C.593 0 0 .593 0 1.325v21.351C0 23.407.593 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.323-.593 1.323-1.325V1.325C24 .593 23.407 0 22.675 0z"/>
              </svg>
            </a>
          )}
          {socialLinks.tiktok && (
            <a
              href={socialLinks.tiktok}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-xl bg-white/10 hover:bg-water-600 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
              aria-label="TikTok"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.01.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.16-3.44-3.37-3.46-5.7-.02-1.29.35-2.58.99-3.71 1.3-2.27 3.8-3.74 6.4-3.81V13.8c-1.15.03-2.28.47-3.14 1.27-.85.73-1.33 1.82-1.33 2.94-.01 1.34.82 2.58 2.05 3.13 1.25.56 2.74.5 3.93-.16.71-.4 1.3-1.02 1.57-1.78.17-.46.22-.96.22-1.45.02-5.75.01-11.49.02-17.24V.02Z"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Link Groups -->
      {footerLinks.map((group) => (
        <div>
          <h4 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-4">
            {group.title}
          </h4>
          <ul class="space-y-2.5">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/50 hover:text-pool-400 transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-white/40">
        &copy; {currentYear} {siteName}. All rights reserved.
      </p>
      <p class="text-xs text-white/30">
        Melbourne, Australia 🇦🇺
      </p>
    </div>
  </div>
</footer>
